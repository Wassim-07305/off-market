# ─── Supabase ────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── App ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_SITE_URL is used by digest emails (falls back to NEXT_PUBLIC_APP_URL)
# NEXT_PUBLIC_SITE_URL=https://offmarket.app

# ─── Stripe ──────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Resend (email) ─────────────────────────────────────────────────
RESEND_API_KEY=re_...
# EMAIL_FROM=Off-Market <noreply@offmarket.app>

# ─── OpenRouter (AI) ────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...

# ─── Google Calendar OAuth ───────────────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ─── Wise (payments) ────────────────────────────────────────────────
WISE_API_KEY=your-wise-api-key
WISE_PROFILE_ID=your-wise-profile-id
# WISE_SANDBOX=true

# ─── Push Notifications (VAPID) ─────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
# VAPID_EMAIL=mailto:contact@offmarket.app

# ─── Cloudflare TURN (WebRTC) ───────────────────────────────────────
NEXT_PUBLIC_CLOUDFLARE_TURN_TOKEN_ID=your-turn-token-id
NEXT_PUBLIC_CLOUDFLARE_TURN_API_TOKEN=your-turn-api-token

# ─── Cron jobs ───────────────────────────────────────────────────────
CRON_SECRET=your-cron-secret

# ─── Unipile (unified messaging) ────────────────────────────────────
UNIPILE_API_KEY=your-unipile-api-key
UNIPILE_BASE_URL=https://api33.unipile.com:16338

# ─── Vercel (auto-set on Vercel) ────────────────────────────────────
# VERCEL_URL=your-vercel-deployment.vercel.app
