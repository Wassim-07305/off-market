# ─── Supabase ────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── App ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Stripe ──────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Resend (email) ─────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ─── AI ──────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
# GROQ_API_KEY=gsk_...
# OPENAI_API_KEY=sk-...
# JINA_API_KEY=jina_...

# ─── Google Calendar OAuth ───────────────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ─── Google Analytics ────────────────────────────────────────────────
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Push Notifications (VAPID) ─────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
# VAPID_EMAIL=mailto:contact@offmarket.app

# ─── Cloudflare TURN (WebRTC) ───────────────────────────────────────
NEXT_PUBLIC_CLOUDFLARE_TURN_TOKEN_ID=your-turn-token-id
NEXT_PUBLIC_CLOUDFLARE_TURN_API_TOKEN=your-turn-api-token

# ─── Cron jobs ───────────────────────────────────────────────────────
CRON_SECRET=your-cron-secret

# ─── Unipile (unified messaging) ────────────────────────────────────
UNIPILE_API_KEY=your-unipile-api-key
UNIPILE_BASE_URL=https://api33.unipile.com:16338

# ─── Backblaze B2 (storage) ─────────────────────────────────────────
B2_KEY_ID=your-b2-key-id
B2_APP_KEY=your-b2-app-key
B2_BUCKET_NAME=your-bucket-name
B2_REGION=eu-central-003
B2_ENDPOINT=https://s3.eu-central-003.backblazeb2.com

# ─── YouTube Data API v3 ────────────────────────────────────────────
YOUTUBE_CLIENT_ID=your-client-id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your-client-secret
YOUTUBE_REFRESH_TOKEN=your-refresh-token

# ─── Apify (data enrichment) ────────────────────────────────────────
# APIFY_TOKEN=apify_api_...

# ─── Vercel (auto-set on Vercel) ────────────────────────────────────
# VERCEL_URL=your-vercel-deployment.vercel.app
